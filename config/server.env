# whisper.cpp HTTP server configuration
# Loaded by the systemd service unit

# Network
WHISPER_HOST=0.0.0.0
WHISPER_PORT=8178

# Model — path to ggml-large-v3.bin
WHISPER_MODEL=/var/haven-ai/data/models/ggml-large-v3.bin

# Inference
WHISPER_THREADS=4          # CPU threads for inference (per request)
WHISPER_PROCESSORS=1       # Parallel request processors
WHISPER_BEAM_SIZE=5        # Beam search width (higher = more accurate, slower)
WHISPER_LANGUAGE=en        # Force language (empty = auto-detect)

# GPU — comment out to disable CUDA offload
WHISPER_GPU_LAYERS=99      # Layers to offload to GPU (99 = all)
